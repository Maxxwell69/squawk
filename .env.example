# Copy to .env at repo root (optional — apps have their own .env.example)

# Overlay (Next.js) — prefix required for browser
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8787/ws
NEXT_PUBLIC_BRIDGE_HTTP=http://127.0.0.1:8787

# Local bridge
LOCAL_BRIDGE_HOST=0.0.0.0
LOCAL_BRIDGE_PORT=8787
FEATURE_MOCK_TTS=true
