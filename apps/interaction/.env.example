# Copy to `apps/interaction/.env.local` for local dev.

# PostgreSQL (local Docker, Neon, Railway Postgres plugin, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# openssl rand -base64 32
AUTH_SECRET=

# Public URL of this app (magic links). Examples:
#   https://crew.squawk.piratemaxx.com
#   http://localhost:3001
AUTH_URL=http://localhost:3001

# First sign-in with this exact email becomes ADMIN (promoted after account is created).
ADMIN_EMAIL=captain@example.com

# SMTP for magic links. Examples:
#   smtp://user:pass@smtp.example.com:587
#   smtps://user:pass@email-smtp.us-east-1.amazonaws.com:465
EMAIL_SERVER=
EMAIL_FROM="Captain Squawks <noreply@piratemaxx.com>"
