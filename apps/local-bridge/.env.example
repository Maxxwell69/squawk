LOCAL_BRIDGE_HOST=0.0.0.0
LOCAL_BRIDGE_PORT=8787
LOG_LEVEL=info

# TTS + audio (PARROT_SPEAK WebSocket)
FEATURE_TTS=true
# mock | elevenlabs | openai
TTS_PROVIDER=mock
# ElevenLabs (when TTS_PROVIDER=elevenlabs) — [API key](https://elevenlabs.io/app/settings/api-keys), [voice id](https://elevenlabs.io/app/voice-library)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# Optional: ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# Optional: ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# Optional: ELEVENLABS_BASE_URL=https://api.elevenlabs.io (or residency URL)
# Optional: ELEVENLABS_VOICE_SETTINGS={"stability":0.5,"similarity_boost":0.75}
# Public origin for /audio/* URLs (no trailing slash). On Railway set to your bridge HTTPS URL.
AUDIO_PUBLIC_BASE_URL=http://127.0.0.1:8787
# Optional override; default: apps/local-bridge/tmp/audio
# AUDIO_TEMP_DIR=

# Optional: require this value on Stream Deck HTTP actions (header x-stream-deck-key or Authorization: Bearer …)
# STREAM_DECK_SECRET=
