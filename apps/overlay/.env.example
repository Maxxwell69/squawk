# Browser-visible — must use NEXT_PUBLIC_
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8787/ws
NEXT_PUBLIC_BRIDGE_HTTP=http://127.0.0.1:8787

# If the overlay is served over HTTPS (e.g. Vercel/Railway) and the bridge is on the public
# internet, use wss:// here — browsers block ws://127.0.0.1 from an https page (mixed content).
# Example: NEXT_PUBLIC_WS_URL=wss://your-bridge.up.railway.app/ws
# TikTok Live Studio / OBS: you can also append to the overlay URL without redeploying:
#   ?squawk_bridge=https://your-bridge.up.railway.app
#   ?squawk_ws=wss://your-bridge.up.railway.app/ws

# Optional: deployed bridge for /dev/parrot-test “Railway” column (same routes as Stream Deck)
# NEXT_PUBLIC_RAILWAY_BRIDGE_HTTP=https://your-bridge.up.railway.app

# Optional: only if bridge has STREAM_DECK_SECRET — for testing Stream Deck routes from the dev panel
# NEXT_PUBLIC_STREAM_DECK_TEST_KEY=
