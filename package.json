{
  "name": "captain-squawks",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm run build:shared && pnpm run build:bridge && pnpm run build:overlay",
    "build:shared": "pnpm --filter @captain-squawks/shared run build",
    "build:bridge": "pnpm --filter @captain-squawks/local-bridge run build",
    "build:overlay": "pnpm --filter @captain-squawks/overlay run build",
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:overlay": "pnpm --filter @captain-squawks/overlay dev",
    "dev:bridge": "pnpm --filter @captain-squawks/local-bridge dev",
    "lint": "pnpm -r run lint"
  },
  "engines": {
    "node": ">=20"
  }
}
